{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "rootDir": "./src",
    "outDir": "./dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": ["src", "src/prisma", "prisma.config.ts"],
  "exclude": ["node_modules", "dist", "eslint.config.mts", "prisma.config.ts"]
}
